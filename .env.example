API_NAME="Sentiment Analysis API"
API_PORT=8000

# Jina AI
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxx
JINA_TIMEOUT=30                        # seconds per embedding call

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # leave blank for local / no-auth

# Collection name (optional, default: sentiments)
COLLECTION_NAME=sentiments

# Security
API_KEY=                               # leave blank to disable auth; set to require X-API-Key header
CORS_ORIGINS=*                         # comma-separated allowed origins

# Limits
MAX_CONTENT_LEN=5000                   # max characters per text input
MAX_TRAIN_ITEMS=256                    # max items per /train request
MAX_IMPORT_ROWS=10000                  # max rows per CSV import
MAX_UPLOAD_MB=10                       # max CSV file size in MB

# Logging
LOG_LEVEL=INFO                         # DEBUG, INFO, WARNING, ERROR
